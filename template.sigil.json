{
  "$schema": "./packages/cli/src/report/schemas/sigil-template.schema.json",
  "name": "sigil-design",
  "displayName": "Sigil TanStack Start",
  "defaultPackageManager": "pnpm",
  "rewrite": [
    {
      "file": "package.json",
      "jsonPath": "$.name",
      "value": "{{packageName}}"
    },
    {
      "file": "apps/web/package.json",
      "jsonPath": "$.scripts.dev",
      "replace": ["portless sigil", "portless {{devHost}}"]
    }
  ],
  "exclude": [
    "node_modules",
    "dist",
    ".turbo",
    ".output",
    ".nitro",
    ".tanstack",
    ".vinxi",
    ".vercel",
    "coverage",
    ".git",
    ".DS_Store",
    "**/routeTree.gen.ts",
    "apps/web/public/r",
    "apps/web/public/llms.txt",
    "packages/ui/.registry-staging",
    "docs.local",
    ".agents/memory",
    ".agents/settings",
    ".agents/skills",
    ".agents/store",
    ".playwright-mcp",
    ".omc",
    "traces",
    ".env",
    ".env.local",
    ".env.development.local",
    ".env.test.local",
    ".env.production.local"
  ],
  "postCreate": ["pnpm install"]
}
