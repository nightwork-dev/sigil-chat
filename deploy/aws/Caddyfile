{
	admin off
	http_port 8080
	https_port 8443
}
{$PUBLIC_HOST} {
	encode zstd gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "no-referrer"
		-Server
	}

	handle /healthz {
		reverse_proxy web:3000
	}

	handle /eve/* {
		reverse_proxy eve:3001
	}

	handle {
		reverse_proxy web:3000
	}
}
