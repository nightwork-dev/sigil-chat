# Copy to deploy.env.local on the EC2 host. This file is intentionally not a
# launch config: fill host-specific values there, not in the repository.
PUBLIC_HOST=chat.example.invalid
SIGIL_INSTALLATION_ID=replace-with-a-non-secret-unique-id
SIGIL_SECRET_DIR=/srv/sigil-chat/secrets

# Replace each with an immutable local image digest after `docker build`.
SIGIL_MIGRATE_IMAGE=sigil-chat-migrate@sha256:replace-at-launch
SIGIL_WEB_IMAGE=sigil-chat-web@sha256:replace-at-launch
SIGIL_EVE_IMAGE=sigil-chat-eve@sha256:replace-at-launch
SIGIL_GONK_IMAGE=sigil-chat-gonk@sha256:replace-at-launch
