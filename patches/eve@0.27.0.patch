--- /dev/null
+++ b/dist/src/runtime/connections/scoped-mcp-client.js
@@ -0,0 +1,34 @@
+import { createMCPClient } from "#compiled/@ai-sdk/mcp/index.js"
+import {
+  McpConnectionClient,
+  passesToolFilter,
+  resolveHeaders,
+} from "#runtime/connections/mcp-client.js"
+
+class ScopedMcpConnectionClient {
+  constructor(connection) {
+    this.connection = connection
+    this.metadataClient = new McpConnectionClient(connection)
+  }
+  connect() { return this.metadataClient.connect() }
+  getToolMetadata() { return this.metadataClient.getToolMetadata() }
+  getTools() { return this.metadataClient.getTools() }
+  async executeTool(name, args, options) {
+    const headers = await resolveHeaders(this.connection)
+    const client = await createMCPClient({
+      transport: { type: "http", url: this.connection.url, headers },
+    })
+    try {
+      const listed = await client.listTools()
+      const declared = this.connection.tools
+      const tools = declared === undefined
+        ? listed.tools
+        : listed.tools.filter((tool) => passesToolFilter(tool.name, declared))
+      const tool = client.toolsFromDefinitions({ tools })[name]
+      if (tool?.execute === undefined) throw new Error(`Tool "${name}" not found in connection "${this.connection.connectionName}".`)
+      return await tool.execute(args, { abortSignal: options?.abortSignal })
+    } finally { await client.close() }
+  }
+  close() { return this.metadataClient.close() }
+}
+export { ScopedMcpConnectionClient }
