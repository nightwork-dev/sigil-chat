{
  "name": "sigil-chat",
  "version": "0.0.1",
  "license": "Apache-2.0",
  "private": true,
  "scripts": {
    "auth:generate": "pnpm --filter web auth:generate",
    "auth:migrate": "pnpm --filter web auth:migrate",
    "seed:scope-composition": "pnpm --filter web seed:scope-composition",
    "build": "turbo build",
    "dev": "node scripts/dev.mjs",
    "dev:reset": "node scripts/dev-reset.mjs",
    "dev:restore": "node scripts/dev-restore.mjs",
    "lint": "turbo lint",
    "lint:design": "pnpm --filter @workspace/ui lint:design",
    "format": "turbo format",
    "test": "node --test scripts/dev-*.test.mjs && pnpm -r --if-present test",
    "typecheck": "turbo typecheck",
    "verify": "pnpm lint && pnpm typecheck && pnpm test",
    "overlay:stage": "pnpm --filter @sigil-design/chat-overlay stage"
  },
  "devDependencies": {
    "@tanstack/eslint-config": "^0.3.0",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.8",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@9.0.6",
  "engines": {
    "node": ">=24"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@mongodb-js/zstd",
      "better-sqlite3",
      "esbuild",
      "eve",
      "unrs-resolver"
    ],
    "patchedDependencies": {
      "eve@0.25.2": "patches/eve@0.25.2.patch"
    }
  }
}
