{
  "name": "sigil-chat",
  "version": "0.0.1",
  "license": "Apache-2.0",
  "private": true,
  "scripts": {
    "auth:generate": "pnpm --filter web auth:generate",
    "auth:migrate": "pnpm --filter web auth:migrate",
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "lint:design": "pnpm --filter @workspace/ui lint:design",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "overlay:stage": "pnpm --filter @sigil-design/chat-overlay stage"
  },
  "devDependencies": {
    "@tanstack/eslint-config": "^0.3.0",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.8",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@9.0.6",
  "engines": {
    "node": ">=24"
  },
  "pnpm": {
    "patchedDependencies": {
      "@gonk/eve-host@0.5.0": "patches/@gonk__eve-host@0.5.0.patch",
      "eve@0.25.2": "patches/eve@0.25.2.patch"
    },
    "overrides": {
      "@gonk/memory": "file:./vendor/gonk-memory-0.5.0.tgz",
      "@gonk/persona": "file:./vendor/gonk-persona-0.5.0.tgz",
      "@gonk/eve-host": "file:./vendor/gonk-eve-host-0.5.0.tgz"
    }
  }
}
