{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sigil.dev/schemas/report-manifest-1.0.json",
  "title": "Sigil Report Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "title",
    "createdAt",
    "source",
    "navigation",
    "skills"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "title": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "createdAt": { "type": "string" },
    "author": { "type": "string" },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entry", "repo"],
      "properties": {
        "entry": { "type": "string", "minLength": 1 },
        "repo": { "type": "string", "minLength": 1 },
        "commit": { "type": "string", "pattern": "^[0-9a-f]{40,64}$" },
        "digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
      }
    },
    "navigation": {
      "type": "array",
      "items": { "$ref": "#/$defs/navigationEntry" }
    },
    "skills": {
      "type": "array",
      "items": { "$ref": "#/$defs/advisorySkill" }
    }
  },
  "$defs": {
    "navigationEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "selector"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "selector": { "type": "string", "pattern": "^#" },
        "summary": { "type": "string" }
      }
    },
    "advisorySkill": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "description", "content", "scope", "trust"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "content": { "type": "string", "minLength": 1 },
        "scope": { "type": "string", "minLength": 1 },
        "trust": { "const": "advisory" }
      }
    }
  }
}
