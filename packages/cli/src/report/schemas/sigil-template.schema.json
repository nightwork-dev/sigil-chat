{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sigil.dev/schemas/template-1.0.json",
  "title": "Sigil Template Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "defaultPackageManager", "exclude"],
  "properties": {
    "$schema": { "type": "string" },
    "name": { "type": "string", "minLength": 1 },
    "displayName": { "type": "string", "minLength": 1 },
    "defaultPackageManager": {
      "enum": ["pnpm", "npm", "yarn", "bun"]
    },
    "exclude": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "rewrite": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["file", "jsonPath"],
        "properties": {
          "file": { "type": "string", "minLength": 1 },
          "jsonPath": { "type": "string", "pattern": "^\\$\\." },
          "value": { "type": "string" },
          "replace": {
            "type": "array",
            "prefixItems": [{ "type": "string" }, { "type": "string" }],
            "minItems": 2,
            "maxItems": 2
          }
        },
        "oneOf": [
          { "required": ["value"], "not": { "required": ["replace"] } },
          { "required": ["replace"], "not": { "required": ["value"] } }
        ]
      }
    },
    "postCreate": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
