{
  "name": "sigil",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "type": "module",
  "description": "Sigil CLI — scaffold apps and render portable reports from the Sigil template.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abrisene/sigil-design.git"
  },
  "bin": {
    "sigil": "./dist/sigil.js",
    "create-sigil": "./dist/create-sigil.js"
  },
  "exports": {
    "./report": {
      "types": "./dist/report.d.ts",
      "import": "./dist/report.js"
    },
    "./schemas/*": "./src/report/schemas/*.json"
  },
  "files": [
    "dist",
    "README.md",
    "src/report/schemas",
    "template"
  ],
  "scripts": {
    "build": "tsup",
    "prepack": "pnpm build && node src/pack-template.mjs",
    "postpack": "node src/clean-packed-template.mjs",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@tailwindcss/vite": "^4.1.18",
    "@vitejs/plugin-react": "^5.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.0.8",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "vite": "^7.2.4",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "devDependencies": {
    "@types/node": "^25.1.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
