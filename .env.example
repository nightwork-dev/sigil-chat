# Copy to .env and fill in. This root .env is the single source of truth for
# local dev secrets, shared by apps/gonk (loads it via process.loadEnvFile) and
# apps/agent (apps/agent/.env symlinks here; `eve dev` loads it natively).

# Bearer token authenticating the Eve <-> Gonk MCP transport. Any sufficiently
# random value works locally; both processes read THIS file so they always match.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
GONK_MCP_KEY=

# Optional: override Eve's default subscription-backed model with a bare OpenAI slug.
# CODEX_MODEL=

# Optional: override the MCP endpoint Eve connects to (defaults to the Portless URL).
# GONK_MCP_URL=
