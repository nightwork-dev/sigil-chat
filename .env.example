# Public service topology. Defaults match the Portless development hosts.
EVE_ORIGIN=http://sigil-chat-agent.localhost:1355
GONK_MCP_URL=http://sigil-chat-gonk.localhost:1355/mcp
VITE_API_BASE_URL=http://localhost:8787
PAGES_BASE=/
CODEX_MODEL=gpt-5.6-terra
SIGIL_CHAT_GRAPH_PATH=.data/reducer-graph.json
SIGIL_CHAT_REVIEW_PATH=.data/review-document.json

# Server-only. Use the same bearer token for the agent client and Gonk server.
GONK_MCP_KEY=replace-with-a-local-secret
PORT=8808
