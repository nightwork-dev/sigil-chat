# Copy to .env and fill in. This root .env is the single source of truth for
# local dev secrets, shared by apps/gonk (loads it via process.loadEnvFile) and
# apps/agent (apps/agent/.env symlinks here; `eve dev` loads it natively).

# Public application branding. In development the tab title and procedural SVG
# favicon automatically gain a stable color/label from Portless's branch-derived
# worktree namespace (falling back to the worktree directory). Set
# SIGIL_INSTANCE_LABEL= to disable that inference, or provide an explicit
# label/color for a named preview. PORTLESS_URL supplies the canonical origin.
# SIGIL_APP_NAME=Sigil Chat
# SIGIL_APP_TITLE=Sigil Chat — agentic conversations
# SIGIL_APP_DESCRIPTION=An agentic chat workspace built with Sigil and Gonk.
# SIGIL_APP_ORIGIN=https://chat.example.com
# SIGIL_BRAND_COLOR=#b58b35
# SIGIL_INSTANCE_LABEL=preview
# SIGIL_SHARE_IMAGE_URL=/icon-512.png

# Bearer token authenticating the Eve <-> Gonk MCP transport. Any sufficiently
# random value works locally; both processes read THIS file so they always match.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
GONK_MCP_KEY=

# Human account persistence. Local development defaults to
# file:.data/sigil-chat.db and creates a stable .data/auth-secret automatically.
# Run `pnpm auth:migrate` before starting the web app.
# SIGIL_DATABASE_URL=file:.data/sigil-chat.db
# SIGIL_DATABASE_AUTH_TOKEN=
# BETTER_AUTH_SECRET=
# BETTER_AUTH_URL=http://sigil-chat.localhost:1355
# SIGIL_INSTALLATION_ID=sigil-chat-local
# Production-only path to a stable random secret used to digest invitation
# tokens. Generate at least 32 random bytes and mount the file read-only.
# SIGIL_INVITE_TOKEN_PEPPER_FILE=/run/secrets/invite_token_pepper

# Eve verifies Better Auth service tokens through the web app's JWKS endpoint.
# Production requires HTTPS and never permits the local-development bypass.
# SIGIL_EVE_AUTH_ISSUER=http://sigil-chat.localhost:1355
# SIGIL_EVE_AUTH_JWKS_URL=http://sigil-chat.localhost:1355/api/auth/jwks
# Set explicitly to 1 only for deliberate local requests without a JWT.
# SIGIL_EVE_ALLOW_LOCAL_DEV_AUTH=1

# Persona and memory records are shared by the web profile and Eve host. Local
# package scripts default to the repository-level .data directory; deployments
# should point both services at the same mounted identity volume.
# SIGIL_PERSONA_DIR=
# SIGIL_MEMORY_DIR=

# Optional semantic recall provider. Dev default: a local OpenAI-compatible
# endpoint such as LM Studio or oMLX. Leave unset for lexical-only recall.
# SIGIL_EMBEDDING_BASE_URL=http://localhost:1234/v1
# SIGIL_EMBEDDING_MODEL=nomic-embed-text-v1.5
# SIGIL_EMBEDDING_DIM=768
# SIGIL_EMBEDDING_API_KEY=

# Registration closes after the first owner by default. Leave this closed when
# using owner-issued, single-use invitation links.
# SIGIL_AUTH_REGISTRATION=open

# Comma-separated exact origins. Production defaults to BETTER_AUTH_URL only;
# localhost origins are added only outside production.
# SIGIL_AUTH_TRUSTED_ORIGINS=https://chat.example.com

# Optional: override Eve's default subscription-backed model with a bare OpenAI slug.
# CODEX_MODEL=

# Optional: override the MCP endpoint Eve connects to (defaults to the Portless URL).
# GONK_MCP_URL=

# Optional: override where the roadmap work-items store lives. The roadmap is
# persisted as one markdown file per story in an EXTERNAL, co-located git repo
# that is INDEPENDENT of sigil-chat's git (it is never tracked by this repo).
# When unset, it resolves portably to a `sigil-roadmap` directory beside the
# main sigil checkout (derived from `git rev-parse --git-common-dir`). The
# directory is `git init`'d on first use and receives a commit on every mutation.
# SIGIL_ROADMAP_DIR=

# Optional: permit image-edit results to be downloaded from exact origins other
# than the configured gateway. Separate multiple origins with commas.
# SIGIL_IMAGE_EDIT_DOWNLOAD_ORIGINS=https://assets.example
