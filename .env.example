# Ordinary local development needs no .env file. `pnpm dev` creates one
# worktree-local data root, service key, database, and owner automatically.
# See docs/guides/configuration.md for optional providers and integrations.

# Standard production configuration
# SIGIL_PUBLIC_URL=https://chat.example.com
# SIGIL_DATA_DIR=/var/lib/sigil-chat
# GONK_MCP_KEY=
# BETTER_AUTH_SECRET=
# SIGIL_INSTALLATION_ID=sigil-chat-production
# SIGIL_INVITE_TOKEN_PEPPER_FILE=/run/secrets/invite_token_pepper

# Optional external database (otherwise SIGIL_DATA_DIR is used)
# SIGIL_DATABASE_URL=file:/var/lib/sigil-chat/sigil-chat.db

# Optional non-standard topology
# EVE_ORIGIN=
# GONK_MCP_URL=
# SIGIL_EVE_AUTH_JWKS_URL=http://web:3000/api/auth/jwks

# Shared versioned roadmap; intentionally outside disposable SIGIL_DATA_DIR
# SIGIL_ROADMAP_DIR=
