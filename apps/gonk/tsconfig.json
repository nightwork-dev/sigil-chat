{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "types": ["node"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@workspace/graph/*": ["../../packages/graph/src/*"],
      "@workspace/graph-store/*": ["../../packages/graph-store/src/*"],
      "@workspace/review-store": ["../../packages/review-store/src/repository.ts"],
      "@workspace/review-store/*": ["../../packages/review-store/src/*"]
    }
  },
  "include": ["src/**/*.ts"]
}
