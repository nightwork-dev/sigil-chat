{
  "name": "sigil-chat-agent",
  "version": "0.0.1",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "eve build",
    "dev": "portless run --name sigil-chat-agent eve dev --no-ui --host 127.0.0.1",
    "healthcheck": "node scripts/healthcheck.mjs",
    "start": "eve start --host 127.0.0.1",
    "test": "vitest run && pnpm test:cold-boot",
    "test:cold-boot": "node scripts/cold-boot-smoke.mjs",
    "test:sandbox": "node scripts/sandbox-smoke.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@gonk/auth": "0.3.1",
    "@gonk/context": "0.3.1",
    "@gonk/eve-host": "0.7.0",
    "@gonk/memory": "0.6.0",
    "@gonk/persona": "0.6.0",
    "@gonk/scope": "0.3.1",
    "@gonk/skills": "0.3.1",
    "@gonk/store": "0.3.1",
    "@gonk/tool-registry": "0.3.1",
    "@workspace/agent-contracts": "workspace:*",
    "@workspace/agent-tools": "workspace:*",
    "@workspace/artifact-store": "workspace:*",
    "@workspace/blackboard-store": "workspace:*",
    "@workspace/graph-store": "workspace:*",
    "@workspace/review-store": "workspace:*",
    "@workspace/runtime-env": "workspace:*",
    "@workspace/work-items-store": "workspace:*",
    "ai": "^7.0.26",
    "better-sqlite3": "12.10.0",
    "eve": "0.27.0",
    "jose": "^6.1.3",
    "just-bash": "^3.1.0",
    "microsandbox": "0.6.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.1.0",
    "typescript": "5.9.3",
    "vitest": "^3.2.6"
  }
}
