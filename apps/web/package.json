{
  "name": "web",
  "version": "0.0.1",
  "license": "Apache-2.0",
  "type": "module",
  "private": true,
  "scripts": {
    "auth:generate": "tsx scripts/auth-generate.ts",
    "auth:migrate": "tsx scripts/auth-migrate.ts",
    "seed:scope-composition": "tsx scripts/seed-scope-composition-dev.ts",
    "agent-threads:claim-legacy": "tsx scripts/claim-agent-thread-memberships.ts",
    "gaze:setup": "node scripts/setup-gaze-assets.mjs",
    "predev": "pnpm gaze:setup",
    "dev": "portless run --name sigil-chat vite dev --host",
    "prebuild": "pnpm gaze:setup",
    "build": "pnpm --filter @workspace/ui registry:build && vite build",
    "prebuild:static": "pnpm gaze:setup",
    "build:static": "vite build --config vite.config.static.ts && node scripts/finalize-spa.mjs",
    "preview": "vite preview",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "vite build --emptyOutDir=false && tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@gonk/comms": "0.5.0",
    "@gonk/auth": "0.3.1",
    "@gonk/memory": "0.6.0",
    "@gonk/persona": "0.6.0",
    "@gonk/scope": "0.3.1",
    "@gonk/store": "0.3.1",
    "@libsql/client": "^0.15.15",
    "@mediapipe/tasks-vision": "0.10.35",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-hotkeys": "^0.10.0",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "^1.170.16",
    "@tanstack/react-start": "^1.168.26",
    "@tanstack/router-plugin": "^1.168.18",
    "@workspace/agent-contracts": "workspace:*",
    "@workspace/agent-tools": "workspace:*",
    "@workspace/artifact-store": "workspace:*",
    "@workspace/blackboard-store": "workspace:*",
    "@workspace/chat": "workspace:*",
    "@workspace/data": "workspace:*",
    "@workspace/graph": "workspace:*",
    "@workspace/graph-store": "workspace:*",
    "@workspace/review": "workspace:*",
    "@workspace/review-store": "workspace:*",
    "@workspace/runtime-env": "workspace:*",
    "@workspace/ui": "workspace:*",
    "@workspace/work-items-store": "workspace:*",
    "@xyflow/react": "12.11.2",
    "@zigil/agent-eve": "^0.1.6",
    "@zigil/agent-react": "^0.1.4",
    "@zigil/agent-react-query": "^0.1.1",
    "@zigil/agent-surface": "^0.1.1",
    "better-auth": "^1.6.2",
    "date-fns": "^4.1.0",
    "kysely": "^0.28.17",
    "kysely-libsql": "^0.7.1",
    "lucide-react": "^0.577.0",
    "nitro": "latest",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.0",
    "sonner": "^2.0.7",
    "tailwindcss": "^4.1.18",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "devDependencies": {
    "@tanstack/eslint-config": "^0.3.0",
    "@types/node": "^25.1.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vitest": "^3.2.6"
  }
}
