{
  "id": "sigil-chat",
  "requiredFiles": [
    { "path": "apps/agent/package.json" },
    { "path": "apps/gonk/package.json" },
    { "path": "packages/agent-contracts/package.json" },
    { "path": "packages/runtime-env/package.json" },
    { "path": "fixtures/application/sigil-chat.yaml" },
    { "path": "apps/web/src/routes/_app/chat.tsx" }
  ],
  "packageJson": [
    {
      "path": "apps/agent/package.json",
      "requiredScripts": ["dev", "build", "typecheck"],
      "requiredDependencies": ["eve", "@workspace/runtime-env"]
    },
    {
      "path": "apps/gonk/package.json",
      "requiredScripts": ["dev", "start", "typecheck"],
      "requiredDependencies": [
        "@gonk/tool-registry",
        "@workspace/agent-contracts",
        "@workspace/runtime-env"
      ]
    }
  ],
  "environment": [
    {
      "path": ".env.example",
      "variables": [
        { "name": "SIGIL_PUBLIC_URL", "url": "http", "public": true },
        { "name": "SIGIL_DATA_DIR" },
        { "name": "EVE_ORIGIN", "url": "http", "public": true },
        { "name": "GONK_MCP_URL", "url": "http", "public": true },
        { "name": "SIGIL_EVE_AUTH_JWKS_URL", "url": "http" },
        { "name": "GONK_MCP_KEY" }
      ]
    }
  ],
  "serviceProbes": [
    {
      "name": "eve-agent",
      "url": "http://sigil-chat-agent.localhost:1355/eve/v1/info",
      "expectedStatuses": [200],
      "timeoutMs": 2000,
      "remediation": "Start the Eve app with pnpm --filter sigil-chat-agent dev."
    },
    {
      "name": "gonk",
      "url": "http://sigil-chat-gonk.localhost:1355/live",
      "expectedStatuses": [200],
      "timeoutMs": 2000,
      "remediation": "Start the complete development stack with pnpm dev."
    }
  ]
}
