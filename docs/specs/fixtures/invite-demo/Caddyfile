{
	admin off
	http_port 8080
	https_port 8443
}

{$PUBLIC_HOST:invite-demo.invalid} {
	# Invite tokens use URL fragments and redacted request bodies. Access logging
	# stays off for this disposable demo so tokens cannot leak through URI logs.
	encode zstd gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "no-referrer"
		-Server
	}

	handle /healthz {
		respond "ok" 200
	}

	handle /eve/* {
		reverse_proxy eve:3001
	}

	handle /img/* {
		reverse_proxy gonk:8808
	}

	handle {
		reverse_proxy web:3000
	}
}
