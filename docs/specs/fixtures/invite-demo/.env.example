# Deliberately non-routable and non-secret values for `docker compose config`.
PUBLIC_HOST=invite-demo.invalid

# Local, intentionally nonexistent spec image names. Execution must pin reviewed
# production images by digest in an out-of-repo launch record.
SIGIL_WEB_IMAGE=sigil-chat-web:spec-only
SIGIL_EVE_IMAGE=sigil-chat-eve:spec-only
SIGIL_GONK_IMAGE=sigil-chat-gonk:spec-only

# Host paths are examples only. Secret files are intentionally absent from this
# repository. The device-auth path must be an encrypted persistent mount before
# that profile can pass its gate.
SIGIL_SECRET_DIR=/var/lib/sigil-invite-demo/secrets
SIGIL_CODEX_HOME_PATH=/var/lib/sigil-invite-demo/codex-home
